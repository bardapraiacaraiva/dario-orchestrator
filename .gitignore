# =============================================================================
# DARIO Orchestrator — Whitelist .gitignore
# =============================================================================
# Strategy: ignore EVERYTHING, then un-ignore the product (orchestrator + skills)
# This protects credentials, sessions, history, and personal data.
# =============================================================================

# --- Ignore everything by default ---
*

# --- Allow .gitignore itself ---
!.gitignore

# --- Allow GitHub Actions ---
!.github/
!.github/**

# --- Allow README ---
!README.md

# --- Allow orchestrator (the product) ---
!orchestrator/
!orchestrator/install.sh
!orchestrator/orch
!orchestrator/*.py
!orchestrator/*.html
!orchestrator/.license
!orchestrator/tasks/
!orchestrator/tasks/templates/
!orchestrator/tasks/templates/**
!orchestrator/quality/
!orchestrator/quality/domain-playbooks.yaml
!orchestrator/quality/eval-baseline.yaml

# --- Allow tests, LEX-BR agent, DEMETER squad ---
!orchestrator/tests/
!orchestrator/tests/**
!orchestrator/lex-br/
!orchestrator/lex-br/**
!orchestrator/demeter/
!orchestrator/demeter/**

# --- But never commit pycache ---
**/__pycache__/
*.pyc

# --- Exclude orchestrator personal/generated data ---
orchestrator/company.yaml
orchestrator/last_pulse.yaml
orchestrator/notifications.yaml
orchestrator/open-dashboard.bat
# orchestrator/license_manager.py  # v11.1.2: now safe to publish (secret in env)
# v11.1.2 — Trial fingerprint, HMAC keys
orchestrator/create_batch_tasks.py
orchestrator/export_outputs.py
orchestrator/dario.db
orchestrator/tasks/active/
orchestrator/tasks/done/
orchestrator/audit/
orchestrator/budgets/

# --- Allow all skills ---
!skills/
!skills/*/
!skills/*/SKILL.md

# --- Exclude external cloned repos inside skills ---
skills/a360-framework-lite/

# --- Exclude everything else (explicit) ---
.credentials.json
settings.json
settings.local.json
history.jsonl
projects/
sessions/
session-env/
cache/
debug/
file-history/
paste-cache/
plans/
plugins/
shell-snapshots/
tasks/
telemetry/
backups/
agent-memory/
agents/
commands/
mcp-needs-auth-cache.json
policy-limits.json

# v11.1.2 — Local MASTER_SECRET for HMAC key signing (NEVER commit)
orchestrator/.master_secret
orchestrator/.trial_fingerprint
orchestrator/dev.flag


# v11.4 — 6 new squads
!orchestrator/orion/
!orchestrator/orion/**
!orchestrator/obsidian-corp/
!orchestrator/obsidian-corp/**
!orchestrator/medik/
!orchestrator/medik/**
!orchestrator/campus/
!orchestrator/campus/**
!orchestrator/aegis/
!orchestrator/aegis/**
!orchestrator/zenith/
!orchestrator/zenith/**

# v11.5 — GAIA + NOMOS squads
!orchestrator/gaia/
!orchestrator/gaia/**
!orchestrator/nomos/
!orchestrator/nomos/**
