# =============================================================================
# DARIO Orchestrator — Whitelist .gitignore
# =============================================================================
# Strategy: ignore EVERYTHING, then un-ignore the product (orchestrator + skills)
# This protects credentials, sessions, history, and personal data.
# =============================================================================

# --- Ignore everything by default ---
*

# --- Allow .gitignore itself ---
!.gitignore

# --- Allow GitHub Actions ---
!.github/
!.github/**

# --- Allow README ---
!README.md

# --- Allow LICENSE (root) ---
!LICENSE
!COPYING
!NOTICE

# --- Allow orchestrator (the product) ---
!orchestrator/
!orchestrator/install.sh
!orchestrator/orch
!orchestrator/*.py
!orchestrator/*.html
!orchestrator/*.md
!orchestrator/.license
!orchestrator/LICENSE
!orchestrator/COPYING
!orchestrator/NOTICE
!orchestrator/tasks/
!orchestrator/tasks/templates/
!orchestrator/tasks/templates/**
!orchestrator/scripts/
!orchestrator/scripts/*.py
!orchestrator/scripts/*.ps1
!orchestrator/scripts/*.bat
!orchestrator/scripts/*.sh
!orchestrator/bundles/
!orchestrator/bundles/*.yaml
!orchestrator/prometheus/
!orchestrator/prometheus/*.md
!orchestrator/prometheus/findings/
!orchestrator/prometheus/findings/*.yaml
!orchestrator/quality/
!orchestrator/quality/domain-playbooks.yaml
!orchestrator/quality/eval-baseline.yaml
!orchestrator/quality/client-revenue.yaml.example

# --- Allow Padrão A pre-flight validator config (Tier 2 briefing rules) ---
!orchestrator/config/padrao_a_briefing_validators.yaml

# --- Allow project type classification (dev vs client budget breakdown) ---
!orchestrator/config/project_types.yaml

# --- Allow versioned git hooks (used via core.hooksPath) ---
!orchestrator/scripts/hooks/
!orchestrator/scripts/hooks/*

# --- Allow test suite + pytest config ---
!orchestrator/tests/
!orchestrator/tests/*.py
!orchestrator/pytest.ini

# --- Allow tool scripts ---
!orchestrator/tools/
!orchestrator/tools/*.py

# --- Allow project config + lock (Onda 1 #1) ---
!orchestrator/pyproject.toml
!orchestrator/uv.lock

# --- Allow Pydantic schemas package (Onda 1 #2) ---
!orchestrator/schemas/
!orchestrator/schemas/*.py

# --- Allow upgrades package (Onda 2 #1 — relocated from *_upgrades.py) ---
!orchestrator/upgrades/
!orchestrator/upgrades/*.py

# --- Allow Onda 7 #1 core sub-modules ---
!orchestrator/upgrades/core_checkpoints.py
!orchestrator/upgrades/core_engines.py

# --- Allow runners + providers packages (Onda 2 #2 — relocated *_runner.py / api_executor.py) ---
!orchestrator/runners/
!orchestrator/runners/*.py
!orchestrator/providers/
!orchestrator/providers/*.py

# --- Allow segmented config (Onda 2 #3 — split from company.yaml monolith) ---
# Note: orchestrator/company.yaml itself stays excluded (line ~48: contains
# personal data and is now a generated artefact of config/company_loader.py).
!orchestrator/config/
!orchestrator/config/*.py
!orchestrator/config/company/
!orchestrator/config/company/*.yaml
!orchestrator/config/company/squads/
!orchestrator/config/company/squads/*.yaml

# --- Allow Langfuse self-host config + other yml/yaml scripts (Onda 1 #4) ---
!orchestrator/scripts/*.yml
!orchestrator/scripts/*.yaml

# --- Allow optimization package (Onda 4 #5 — DSPy pilot) ---
!orchestrator/optimization/
!orchestrator/optimization/*.py
!orchestrator/optimization/*.md
!orchestrator/optimization/compiled/
!orchestrator/optimization/compiled/*.json

# --- Allow chain_schemas extracted from chain_executor (Onda 5 #2) ---
!orchestrator/chain_schemas.py

# --- Allow durable execution pilot package (Onda 5 #5) ---
!orchestrator/durable/
!orchestrator/durable/*.py
# --- Allow Temporal self-host yml (Onda 6 #4) ---
!orchestrator/scripts/temporal-self-host.yml

# --- Allow license server (Onda 8) ---
!orchestrator/license_server/
!orchestrator/license_server/*.py
!orchestrator/license_server/*.md
!orchestrator/license_server/Dockerfile
!orchestrator/license_client.py

# --- Allow Onda 9 anti-piracy artefacts ---
!orchestrator/ANTI_PIRACY.md
!orchestrator/build_obfuscated.py
!orchestrator/scripts/dario_license.spec
!orchestrator/scripts/sign_bundle.py

# Generated by build_obfuscated.py — never commit
orchestrator/setup_obfuscated.py
orchestrator/*.c
orchestrator/*.pyd
orchestrator/*.so
orchestrator/license_server/*.c
orchestrator/license_server/*.pyd
orchestrator/license_server/*.so
orchestrator/build/
orchestrator/dist/

# --- Exclude orchestrator personal/generated data ---
orchestrator/company.yaml
orchestrator/last_pulse.yaml
orchestrator/notifications.yaml
orchestrator/open-dashboard.bat
# orchestrator/license_manager.py  # v11.1.2: now safe to publish (secret in env)
# v11.1.2 — Trial fingerprint, HMAC keys
orchestrator/create_batch_tasks.py
orchestrator/export_outputs.py
orchestrator/dario.db
orchestrator/tasks/active/
orchestrator/tasks/done/
orchestrator/audit/
orchestrator/budgets/

# --- Allow all skills ---
!skills/
!skills/*/
!skills/*/SKILL.md

# --- Exclude external cloned repos inside skills ---
skills/a360-framework-lite/

# --- Exclude everything else (explicit) ---
.credentials.json
settings.json
settings.local.json
history.jsonl
projects/
sessions/
session-env/
cache/
debug/
file-history/
paste-cache/
plans/
plugins/
shell-snapshots/
tasks/
telemetry/
backups/
agent-memory/
agents/
commands/
mcp-needs-auth-cache.json
policy-limits.json

# v11.1.2 — Local MASTER_SECRET for HMAC key signing (NEVER commit)
orchestrator/.master_secret
orchestrator/.trial_fingerprint
orchestrator/dev.flag


