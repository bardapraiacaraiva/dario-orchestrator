#!/usr/bin/env bash
# DARIO Orchestrator pre-push hook
# ──────────────────────────────────────────────────────────────────────
# Runs the fast (non-slow-marked) test suite before any push.
# Blocks the push on any actual test failure or collection error.
# (VIP stubs removed 2026-05-25, Risk #7 — no more tolerated import errors.)
#
# Install via:
#   git config core.hooksPath orchestrator/scripts/hooks
#
# Skip (use only when truly needed):
#   git push --no-verify
#
# Performance target: complete in <30s. If it grows beyond that,
# split into pre-push (smoke) + a separate CI gate (full).

set -u

ORCH_DIR="$HOME/.claude/orchestrator"

if [ ! -d "$ORCH_DIR" ]; then
    echo "[pre-push] DARIO orchestrator dir not found at $ORCH_DIR — skipping tests"
    exit 0
fi

if [ ! -x "$ORCH_DIR/.venv/Scripts/python.exe" ] && [ ! -x "$ORCH_DIR/.venv/bin/python" ]; then
    echo "[pre-push] No virtualenv found — skipping tests"
    exit 0
fi

if [ -x "$ORCH_DIR/.venv/Scripts/python.exe" ]; then
    PYTHON="$ORCH_DIR/.venv/Scripts/python.exe"
else
    PYTHON="$ORCH_DIR/.venv/bin/python"
fi

cd "$ORCH_DIR"

echo "[pre-push] Running fast test suite (marker: not slow)…"
START=$(date +%s)

# Marker deselection:
#   not slow — skip tests >5s (subprocess, LLM, embeddings)
# Collection errors now fail the push (no more VIP stubs to tolerate).
OUTPUT=$("$PYTHON" -m pytest -m "not slow" \
    -q --no-header --tb=line 2>&1)
STATUS=$?

ELAPSED=$(($(date +%s) - START))

# Parse the pytest summary line to extract pass / fail / error counts.
SUMMARY_LINE=$(echo "$OUTPUT" | tail -1)

if echo "$SUMMARY_LINE" | grep -qE "(^| )[0-9]+ failed"; then
    echo "$OUTPUT" | tail -25
    echo ""
    echo "[pre-push] FAIL — test failures detected (${ELAPSED}s)"
    echo "[pre-push] Fix the failing tests, then re-run the push."
    echo "[pre-push] Emergency bypass (use sparingly): git push --no-verify"
    exit 1
fi

PASSED=$(echo "$SUMMARY_LINE" | grep -oE "[0-9]+ passed" | head -1 | grep -oE "[0-9]+" || echo "0")
ERRORS=$(echo "$SUMMARY_LINE" | grep -oE "[0-9]+ errors?" | head -1 | grep -oE "[0-9]+" || echo "0")

if [ "$ERRORS" -gt 0 ]; then
    echo "$OUTPUT" | tail -25
    echo ""
    echo "[pre-push] FAIL — ${ERRORS} collection error(s) (${ELAPSED}s)"
    echo "[pre-push] Fix the import/syntax issue, then re-run the push."
    exit 1
fi

# Sanity check: if pytest ran for <2s OR reported 0 passed, something went
# wrong (test interrupted, pytest crashed, all tests filtered out). Refuse
# to push to avoid false-positive "PASS" like the 2026-05-25 incident where
# a killed pytest reported "0 tests passed (966s)" and proceeded.
# (Fix: Faixa 2 #3 follow-up, 2026-05-25)
MIN_EXPECTED_TESTS=500  # we have 650+ today; tighten as suite grows
if [ "$PASSED" -lt "$MIN_EXPECTED_TESTS" ]; then
    echo "$OUTPUT" | tail -25
    echo ""
    echo "[pre-push] FAIL — only ${PASSED} tests passed (expected >=${MIN_EXPECTED_TESTS})"
    echo "[pre-push] Either pytest was interrupted/killed, the filter is wrong,"
    echo "[pre-push] or many tests are being skipped/missed. Investigate before pushing."
    echo "[pre-push] Emergency bypass: git push --no-verify"
    exit 1
fi

echo "[pre-push] PASS — ${PASSED} tests passed (${ELAPSED}s)"
exit 0
