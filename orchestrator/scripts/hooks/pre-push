#!/usr/bin/env bash
# DARIO Orchestrator pre-push hook
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Runs the fast (non-slow-marked) test suite before any push.
# Blocks the push on any actual test failure or collection error.
# (VIP stubs removed 2026-05-25, Risk #7 вЂ” no more tolerated import errors.)
#
# Install via:
#   git config core.hooksPath orchestrator/scripts/hooks
#
# Skip (use only when truly needed):
#   git push --no-verify
#
# Performance target: complete in <30s. If it grows beyond that,
# split into pre-push (smoke) + a separate CI gate (full).

set -u

ORCH_DIR="$HOME/.claude/orchestrator"

if [ ! -d "$ORCH_DIR" ]; then
    echo "[pre-push] DARIO orchestrator dir not found at $ORCH_DIR вЂ” skipping tests"
    exit 0
fi

if [ ! -x "$ORCH_DIR/.venv/Scripts/python.exe" ] && [ ! -x "$ORCH_DIR/.venv/bin/python" ]; then
    echo "[pre-push] No virtualenv found вЂ” skipping tests"
    exit 0
fi

if [ -x "$ORCH_DIR/.venv/Scripts/python.exe" ]; then
    PYTHON="$ORCH_DIR/.venv/Scripts/python.exe"
else
    PYTHON="$ORCH_DIR/.venv/bin/python"
fi

cd "$ORCH_DIR"

echo "[pre-push] Running fast test suite (marker: not slow)вЂ¦"
START=$(date +%s)

# Marker deselection:
#   not slow вЂ” skip tests >5s (subprocess, LLM, embeddings)
# Collection errors now fail the push (no more VIP stubs to tolerate).
OUTPUT=$("$PYTHON" -m pytest -m "not slow" \
    -q --no-header --tb=line 2>&1)
STATUS=$?

ELAPSED=$(($(date +%s) - START))

# Parse the pytest summary line to extract pass / fail / error counts.
SUMMARY_LINE=$(echo "$OUTPUT" | tail -1)

if echo "$SUMMARY_LINE" | grep -qE "(^| )[0-9]+ failed"; then
    echo "$OUTPUT" | tail -25
    echo ""
    echo "[pre-push] FAIL вЂ” test failures detected (${ELAPSED}s)"
    echo "[pre-push] Fix the failing tests, then re-run the push."
    echo "[pre-push] Emergency bypass (use sparingly): git push --no-verify"
    exit 1
fi

PASSED=$(echo "$SUMMARY_LINE" | grep -oE "[0-9]+ passed" | head -1 | grep -oE "[0-9]+" || echo "0")
ERRORS=$(echo "$SUMMARY_LINE" | grep -oE "[0-9]+ errors?" | head -1 | grep -oE "[0-9]+" || echo "0")

if [ "$ERRORS" -gt 0 ]; then
    echo "$OUTPUT" | tail -25
    echo ""
    echo "[pre-push] FAIL вЂ” ${ERRORS} collection error(s) (${ELAPSED}s)"
    echo "[pre-push] Fix the import/syntax issue, then re-run the push."
    exit 1
fi
echo "[pre-push] PASS вЂ” ${PASSED} tests passed (${ELAPSED}s)"
exit 0
