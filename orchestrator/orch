# ═══════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════
def main():
    args = sys.argv[1:]

    if not args:
        cmd_status()
        return

    cmd = args[0]
    rest = args[1:]

    commands = {
        "status": lambda: cmd_status(),
        "tasks": lambda: cmd_tasks(rest),
        "budget": lambda: cmd_budget(rest),
        "quality": lambda: cmd_quality(),
        "skills": lambda: cmd_skills(rest),
        "logs": lambda: cmd_logs(rest),
        "dashboard": lambda: cmd_dashboard(),
        "license": lambda: cmd_license(),
        "services": lambda: cmd_services(),
        "start": lambda: subprocess.run([sys.executable, str(ORCH / "process_manager.py"), "start"] + rest),
        "stop": lambda: subprocess.run([sys.executable, str(ORCH / "process_manager.py"), "stop"] + rest),
        "restart": lambda: subprocess.run([sys.executable, str(ORCH / "process_manager.py"), "restart"] + rest),
        "health": lambda: subprocess.run([sys.executable, str(ORCH / "process_manager.py"), "health"]),
        "skill": lambda: subprocess.run([sys.executable, str(ORCH / "skill_store.py")] + rest),
        "install": lambda: subprocess.run([sys.executable, str(ORCH / "skill_store.py"), "create"] + rest),
        "search": lambda: subprocess.run([sys.executable, str(ORCH / "skill_store.py"), "search"] + rest),
        "verify": lambda: subprocess.run([sys.executable, str(ORCH / "skill_store.py"), "verify"]),
        "config": lambda: cmd_config(),
        "help": lambda: cmd_help(),
        "pulse": lambda: print(f"  {CYAN}Run in Claude Code:{RESET} /lucas-heartbeat"),
        "auto": lambda: print(f"  {CYAN}Run in Claude Code:{RESET} /loop /lucas-autopilot"),
    }

    if cmd in commands:
        commands[cmd]()
    else:
        print(f"  {RED}Unknown command: {cmd}{RESET}")
        print(f"  Run {CYAN}orch help{RESET} for available commands.")

if __name__ == "__main__":
    main()
