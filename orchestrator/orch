# ═══════════════════════════════════════════════════════════
# CONFIG — Show configuration
# ═══════════════════════════════════════════════════════════
def cmd_config():
    print(header("Configuration"))
    comp = load_yaml(COMPANY)
    company = comp.get("company", {})
    print(f"  Company:    {company.get('name', '?')}")
    print(f"  Owner:      {company.get('owner', '?')}")
    print(f"  Budget:     {company.get('budget', {}).get('monthly_limit_tokens', 0):,} tokens/month")
    print(f"  Alert:      {company.get('budget', {}).get('alert_threshold', 0)*100:.0f}%")
    print(f"  Hard Stop:  {company.get('budget', {}).get('auto_pause_threshold', 0)*100:.0f}%")

    policies = comp.get("execution_policies", {})
    if policies:
        print(f"\n  {c('Execution Policies:', BOLD)}")
        for name, pol in policies.items():
            sla = pol.get("sla_hours", "?")
            review = "review" if pol.get("review_required") else ""
            approval = "approval" if pol.get("approval_required") else ""
            gates = " + ".join(filter(None, [review, approval])) or "none"
            print(f"    {name:<16} SLA: {sla}h  Gates: {gates}")
    print()

