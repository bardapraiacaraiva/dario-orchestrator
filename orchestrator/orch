# LICENSE — Show license info
# ═══════════════════════════════════════════════════════════
def cmd_license():
    script = ORCH / "license.js"
    if script.exists():
        subprocess.run(["node", str(script), "status"])
    else:
        lic = load_yaml(ORCH / ".license")
        if lic:
            print(header("License"))
            for k, v in lic.items():
                print(f"  {k:<20} {v}")
            print()

